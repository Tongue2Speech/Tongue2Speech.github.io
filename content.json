  "pipeline": {
    "sectionTitle": "Processing Pipeline",
    "sectionDesc": "From raw ultrasound scanlines to synthesised speech in four stages.",
    "steps": [
      {
        "id": "ps-1",
        "tag": "Step 01",
        "title": "Raw Scanlines",
        "body": "Phased-array ultrasound probe captures <strong>64 scan lines × 842 pixels/vector</strong> at high frame-rate, stored as raw binary (uint8).",
        "arrowLabel": "CUDA Accelerated",
        "arrowGpu": true,
        "icon": "scanlines"
      },
      {
        "id": "ps-2",
        "tag": "Step 02",
        "title": "Wedge Transform",
        "body": "Scanlines are geometrically mapped to <em>fan-shaped (wedge) video frames</em> mimicking the physical ultrasound beam geometry, via CUDA-accelerated bilinear interpolation.",
        "arrowLabel": "Tongue2Speech Encoder",
        "arrowGpu": false,
        "icon": "wedge"
      },
      {
        "id": "ps-3",
        "tag": "Step 03",
        "title": "Mel-Spectrogram",
        "body": "The model ingests wedge video tensors <code>(B, 1, T, H, W)</code> and predicts <strong>80-bin mel-spectrograms</strong> <code>(B, T, 80)</code> via L1-trained encoder–transformer–projection.",
        "arrowLabel": "Neural Vocoder",
        "arrowGpu": false,
        "icon": "spectrogram"
      },
      {
        "id": "ps-4",
        "tag": "Step 04",
        "title": "HiFi-GAN Synthesis",
        "body": "A pre-trained <strong>HiFi-GAN</strong> vocoder converts the predicted mel-spectrogram into a full-bandwidth waveform at <em>48 kHz</em>, producing natural-sounding speech.",
        "arrowLabel": null,
        "arrowGpu": false,
        "icon": "speaker"
      }
    ]
  },
